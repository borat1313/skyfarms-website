{
  "version": 2,
  "public": true,
  "buildCommand": "",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/styles.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/investors", "destination": "/investors.html" },
    { "source": "/partner", "destination": "/partner.html" },
    { "source": "/partners", "destination": "/partner.html", "permanent": true },
    { "source": "/technology", "destination": "/technology.html" },
    { "source": "/farms", "destination": "/farms.html" }
  ]
}
